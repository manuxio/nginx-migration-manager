# Copy to .env and edit. docker compose reads .env automatically.

# --- host ports (container ports are fixed: nginx 80/443, app 3000) ---
HTTP_PORT=80          # nginx HTTP
HTTPS_PORT=443        # nginx HTTPS (self-signed)
APP_PORT=3000         # admin UI

# --- TLS ---
# Common Name / primary SAN baked into the self-signed certificate.
CERT_CN=localhost

# --- admin UI auth ---
# Set BASIC_AUTH_USER empty to DISABLE auth entirely (not recommended).
BASIC_AUTH_USER=admin
BASIC_AUTH_PASS=changeme
