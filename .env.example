# Copy to .env and edit. docker compose reads .env automatically.

# --- image tag for pull-only deploys from GHCR (e.g. latest, v1.0.0, sha-abc1234) ---
IMAGE_TAG=latest

# --- host ports (container ports are fixed: nginx 80 (HTTP only), app 3000) ---
HTTP_PORT=80          # nginx HTTP (nginx no longer listens on 443)
APP_PORT=3000         # admin UI

# --- admin UI auth ---
# No default password: the app fails CLOSED (returns 503) until BASIC_AUTH_PASS is set.
# Set a strong password below. To run with NO auth on a trusted network, set AUTH_DISABLED=1.
BASIC_AUTH_USER=admin
BASIC_AUTH_PASS=
# AUTH_DISABLED=1

# --- raw config file editor (GUI) ---
# Lets the admin UI browse/edit any file under /etc/nginx (nginx.conf, snippets, …).
# Powerful and dangerous — a bad save can stop nginx loading on the next reload.
# ON by default; set to 0 (or false/no/off) to remove the "Files" button and the API.
FILE_EDITOR=1
